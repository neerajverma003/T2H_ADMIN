# =============================================================================
# T2H ADMIN — Environment Configuration
# =============================================================================
# IMPORTANT: Vite uses the LAST value when a key is duplicated.
# Keep each key defined exactly ONCE. Toggle by commenting/uncommenting.
# =============================================================================

# --- API & CDN ---
# ✅ LOCAL DEVELOPMENT (currently active)
VITE_API_BASE_URL=http://localhost:2000

# 🚀 PRODUCTION — uncomment this and comment the line above before deploying:
#VITE_API_BASE_URL=https://api.trip2honeymoon.com

# CloudFront CDN base (always points to production — S3 keys resolve here)
VITE_CDN_URL=https://media.trip2honeymoon.com

