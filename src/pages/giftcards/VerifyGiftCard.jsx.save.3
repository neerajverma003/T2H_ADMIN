OOimport { useState } from 'react';
import api from '../../utils/api'; // assuming api instance exists

const VerifyGiftCard = () => {
  const [code, setCode] = useState('');
  const [giftCard, setGiftCard] = useState(null);
  const [loading, setLoading] = useState(false);
  const [actionLoading, setActionLoading] = useState(false);
  const [error, setError] = useState('');
  const [success, setSuccess] = useState('');

  const handleVerify = async (e) => {
    e.preventDefault();
    if (!code.trim()) return;

    setLoading(true);
    setError('');
    setSuccess('');
    setGiftCard(null);

    try {
      const response = await api.get(`/admin/giftcard/verify/${code.trim()}`);
      if (response.data.success) {
        setGiftCard(response.data.giftCard);
      } else {
        setError(response.data.msg || 'Gift card not found.');
      }
    } catch (err) {
      setError(err.response?.data?.msg || 'Error verifying gift card.');
    } finally {
      setLoading(false);
    }
  };

  const handleStatusUpdate = async (status) => {
    if (!giftCard) return;

    const confirmMsg = `Are you sure you want to mark this gift card as ${status.toUpperCase()}? This action cannot be undone.`;
    if (!window.confirm(confirmMsg)) return;

    setActionLoading(true);
    setError('');
    setSuccess('');

    try {
      const response = await api.put(`/admin/giftcard/update-status/${giftCard._id}`, { status });
      if (response.data.success) {
        setSuccess(`Successfully updated status to ${status.toUpperCase()}.`);
        setGiftCard({ ...giftCard, status }); // Optimistic update
      } else {
        setError(response.data.msg || 'Failed to update status.');
      }
    } catch (err) {
      setError(err.response?.data?.msg || 'Error updating gift card status.');
    } finally {
      setActionLoading(false);
    }
  };

  const getStatusBadge = (status) => {
    const badges = {
      active: 'bg-green-100 text-green-800',
      invited: 'bg-yellow-100 text-yellow-800',
      created: 'bg-blue-100 text-blue-800',
      expired: 'bg-orange-100 text-orange-800',
      revoked: 'bg-red-100 text-red-800',
      cancelled: 'bg-red-100 text-red-800'
    };
    const defaultBadge = 'bg-gray-100 text-gray-800';
    return badges[status] || defaultBadge;
  };

  return (
    <div className="p-6">
      <h1 className="text-2xl font-bold mb-6 text-gray-800">Verify & Manage Gift Card</h1>

      {/* Search Section */}
      <div className="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
        <form onSubmit={handleVerify} className="max-w-xl">
          <label className="block text-sm font-medium text-gray-700 mb-2">
            Enter Gift Card Public Code (e.g. T2H-ABCDEF)
          </label>
          <div className="flex gap-4">
            <input
              type="text"
              value={code}
              onChange={(e) => setCode(e.target.value.toUpperCase())}
              placeholder="T2H-XXXXXX"
              className="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
              required
            />
            <button
              type="submit"
              disabled={loading || !code.trim()}
              className="px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 disabled:opacity-50 transition"
            >
              {loading ? 'Verifying...' : 'Verify Code'}
            </button>
          </div>
        </form>
      </div>

      {/* Alerts */}
      {error && (
        <div className="bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded-r-lg">
          <p className="text-red-700">{error}</p>
        </div>
      )}
      {success && (
        <div className="bg-green-50 border-l-4 border-green-500 p-4 mb-6 rounded-r-lg">
          <p className="text-green-700">{success}</p>
        </div>
      )}

      {/* Result Section */}
      {giftCard && (
        <div className="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
          <div className="px-6 py-4 border-b border-gray-100 bg-gray-50 flex justify-between items-center">
            <h3 className="text-lg font-semibold text-gray-800">Gift Card Details</h3>
            <span className={`px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider ${getStatusBadge(giftCard.status)}`}>
              {giftCard.status}
            </span>
          </div>
          
          <div className="p-6 grid grid-cols-1 md:grid-cols-2 gap-8">
            {/* Left Column: Financials & Dates */}
            <div className="space-y-4">
              <div>
                <p className="text-sm text-gray-500">Public Code</p>
                <p className="text-xl font-mono font-bold text-gray-900">{giftCard.public_code}</p>
              </div>
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <p className="text-sm text-gray-500">Amount</p>
                  <p className="text-lg font-bold text-gray-900">₹{giftCard.amount}</p>
                </div>
                <div>
                  <p className="text-sm text-gray-500">Remaining Balance</p>
                  <p className="text-lg font-bold text-blue-600">₹{giftCard.remaining_balance}</p>
                </div>
              </div>
              <div>
                <p className="text-sm text-gray-500">Created At</p>
                <p className="text-gray-900">{new Date(giftCard.created_at).toLocaleString()}</p>
              </div>
              <div>
                <p className="text-sm text-gray-500">Expiry Date</p>
                <p className={`font-medium ${new Date(giftCard.expiry_date) < new Date() ? 'text-red-600' : 'text-gray-900'}`}>
                  {new Date(giftCard.expiry_date).toLocaleString()}
                </p>
              </div>
            </div>

            {/* Right Column: User Details */}
            <div className="space-y-4 bg-gray-50 p-4 rounded-lg">
              <div>
                <p className="text-sm text-gray-500 mb-1">Type</p>
                <span className="inline-block px-2 py-1 bg-gray-200 text-gray-700 rounded text-xs uppercase font-semibold">
                  {giftCard.type}
                </span>
              </div>
              
              <div>
                <p className="text-sm text-gray-500">Purchased By (Sender)</p>
                {giftCard.sender ? (
                  <div>
                    <p className="font-medium text-gray-900">{giftCard.sender.name}</p>
                    <p className="text-gray-600 text-sm">{giftCard.sender.email}</p>
                  </div>
                ) : (
                  <p className="text-gray-400 italic">Unknown</p>
                )}
              </div>

              {giftCard.type === 'gift' && (
                <div>
                  <p className="text-sm text-gray-500">Intended Recipient (Invite sent to)</p>
                  <p className="font-medium text-gray-900">{giftCard.recipient_name || 'N/A'}</p>
                  <p className="text-gray-600 text-sm">{giftCard.recipient_email}</p>
                </div>
              )}

              <div>
                <p className="text-sm text-gray-500">Accepted By (Owner)</p>
                {giftCard.accepted_by ? (
                  <div>
                    <p className="font-medium text-gray-900">{giftCard.accepted_by.name}</p>
                    <p className="text-gray-600 text-sm">{giftCard.accepted_by.email}</p>
                  </div>
                ) : (
                  <p className="text-gray-400 italic">Not claimed yet</p>
                )}
              </div>
            </div>
          </div>

          {/* Action Footer */}
          {!['expired', 'revoked', 'cancelled'].includes(giftCard.status) && (
            <div className="px-6 py-4 bg-gray-50 border-t border-gray-100 flex gap-4">
              <button
                onClick={() => handleStatusUpdate('revoked')}
                disabled={actionLoading}
                className="px-4 py-2 bg-red-600 text-white font-medium rounded hover:bg-red-700 transition disabled:opacity-50 flex items-center"
              >
                <svg className="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                Terminate / Revoke Card
              </button>
              
              <button
                onClick={() => handleStatusUpdate('expired')}
                disabled={actionLoading}
                className="px-4 py-2 bg-orange-500 text-white font-medium rounded hover:bg-orange-600 transition disabled:opacity-50 flex items-center"
              >
                <svg className="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                Force Expire
              </button>
            </div>
          )}
        </div>
      )}
    </div>
  );
};

export default VerifyGiftCard;
